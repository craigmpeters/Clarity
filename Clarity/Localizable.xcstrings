    "Supported formats: MP3, AAC, WAV, AIFF, CAF. Maximum duration: 30 seconds. The file will be converted for use as a notification sound." : {
      "comment" : "A footer in the PomodoroSoundSettingsView that explains the file format support and duration restriction.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterstützte Formate: MP3, AAC, WAV, AIFF, CAF. Maximale Dauer: 30 Sekunden. Die Datei wird zur Verwendung als Benachrichtigungston konvertiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supported formats: MP3, AAC, WAV, AIFF, CAF. Maximum duration: 30 seconds. The file will be converted for use as a notification sound."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formatos soportados: MP3, AAC, WAV, AIFF, CAF. Duración máxima: 30 segundos. El archivo se convertirá para usarlo como sonido de notificación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Formats pris en charge : MP3, AAC, WAV, AIFF, CAF. Durée maximale : 30 secondes. Le fichier sera converti pour être utilisé comme son de notification."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
